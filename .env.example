# ═══════════════════════════════════════════════════════════════
# Onsite - Environment Configuration
# Copy this to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# ── Authentication ──
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24
AUTH_ENABLED=0                    # Set to 1 to require login for API access

# ── Data Sources ──
CENSUS_API_KEY=                   # Free: https://api.census.gov/data/key_signup.html
SOCRATA_APP_TOKEN=                # Free: https://dev.socrata.com/register
SHOVELS_API_KEY=                  # Shovels.ai permit data (2,000+ jurisdictions)

# ── Enrichment APIs ──
PROPERTYREACH_API_KEY=            # Skip-trace: https://offer.propertyreach.com/api-checkout
PROPERTYREACH_API_KEY_ALT=        # Rotation key 2
PROPERTYREACH_API_KEY_ALT2=       # Rotation key 3
PROPERTYREACH_API_KEY_ALT3=       # Rotation key 4
PROPERTYREACH_ENABLED=1
PROPERTYREACH_MONTHLY_LIMIT=2000
ATTOM_API_KEY=                    # Property data: https://api.gateway.attomdata.com
ATTOM_RATE_LIMIT=100

# ── Campaign APIs (optional) ──
SENDGRID_API_KEY=                 # Email campaigns: https://sendgrid.com
TWILIO_ACCOUNT_SID=               # SMS campaigns
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=                 # Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:18000/api/auth/google/callback

# ── Admin Console ──
ADMIN_USER=admin                   # Admin console username
ADMIN_PASS=                        # Admin console password
ADMIN_EMAIL=                       # Admin email (seeded as admin role)
APP_URL=http://localhost:18000     # Base URL for redirects
APP_ORIGIN=http://localhost:18000  # Base URL for CORS/Stripe

# ── Billing (Stripe) ──
STRIPE_SECRET_KEY=                # Stripe dashboard: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=           # Stripe publishable key (pk_...)
STRIPE_WEBHOOK_SECRET=            # Stripe webhook signature verification
STRIPE_PRICE_STARTER=             # Stripe price ID for Starter plan
STRIPE_PRICE_PRO=                 # Stripe price ID for Professional plan
STRIPE_PRICE_ENTERPRISE=          # Stripe price ID for Enterprise plan

# ── Infrastructure ──
POSTGRES_PASSWORD=onsite_dev_password
REDIS_PASSWORD=onsite_redis
GRAFANA_PASSWORD=admin
PGADMIN_EMAIL=admin@onsite.com
PGADMIN_PASSWORD=admin

# ── Application Settings ──
CORS_ORIGINS=http://localhost:18000,http://localhost:3000,http://localhost:5173
REFRESH_INTERVAL_SEC=43200        # Data sync interval (12 hours)
ENRICH_ENABLED=1
USE_MASTER_ENRICH=1
AUTO_ENRICH_ON_SYNC=0
SOCRATA_LIMIT=50000
MAX_DAYS_OLD=30                   # Leads older than 30 days are auto-removed
LEADS_RETURN_LIMIT=10000000       # No artificial cap on lead count
RATE_LIMIT_ENABLED=1
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=2000
